{
  "name": "tendrils",
  "version": "0.1.0",
  "description": "Product story map management for LLM agent collaboration",
  "type": "module",
  "bin": {
    "td": "./dist/index.js"
  },
  "files": [
    "dist",
    "commands",
    "ui/dist"
  ],
  "scripts": {
    "prepare": "test -f node_modules/.bin/tsc && npm run build:all || true",
    "build": "tsc",
    "build:ui": "cd ui && npm install && npm run build",
    "build:all": "npm run build && npm run build:ui",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "storymap",
    "cli",
    "llm",
    "agents",
    "project-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fastify": "^5.8.4",
    "node-sqlite3-wasm": "^0.8.55",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
